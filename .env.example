# ── Multi-Agent CFO OS Configuration ──────────────────────────────────

# Database (required — CockroachDB or PostgreSQL connection string)
MACFO_DATABASE_URL=

# EGIS AI Runtime Governance (optional — set to "false" to disable)
EGISAI_ENABLED=true
EGISAI_API_KEY=
EGISAI_APP=multi-agent-cfo-os
EGISAI_ENV=production
